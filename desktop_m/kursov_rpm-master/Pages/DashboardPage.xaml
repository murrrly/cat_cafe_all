<Page x:Class="RPM.DashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Dashboard"
      Background="Transparent">

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="5">
        <StackPanel Margin="15">
            <!-- Заголовок -->
            <TextBlock Text="Панель управления" Style="{StaticResource HeaderTextStyle}" Margin="0,0,0,20"/>

            <!-- Статистика в карточках -->
            <WrapPanel Orientation="Horizontal" HorizontalAlignment="Left">
                <!-- Карточка 1 -->
                <Border Style="{StaticResource CardStyle}" Width="200" Height="100" Margin="0,0,15,15">
                    <StackPanel>
                        <TextBlock Text="Всего заказов сегодня" FontSize="11" Foreground="{StaticResource TextLightBrush}"/>
                        <TextBlock Text="127" FontSize="28" FontWeight="Bold" Foreground="{StaticResource BurgundyMainBrush}" Margin="0,5,0,0"/>
                        <TextBlock Text="+12% за неделю" FontSize="10" Foreground="Green" Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Карточка 2 -->
                <Border Style="{StaticResource CardStyle}" Width="200" Height="100" Margin="0,0,15,15">
                    <StackPanel>
                        <TextBlock Text="Активные заказы" FontSize="11" Foreground="{StaticResource TextLightBrush}"/>
                        <TextBlock Text="15" FontSize="28" FontWeight="Bold" Foreground="{StaticResource BurgundyMainBrush}" Margin="0,5,0,0"/>
                        <TextBlock Text="Требуют внимания" FontSize="10" Foreground="{StaticResource TextLightBrush}" Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Карточка 3 -->
                <Border Style="{StaticResource CardStyle}" Width="200" Height="100" Margin="0,0,15,15">
                    <StackPanel>
                        <TextBlock Text="Выручка сегодня" FontSize="11" Foreground="{StaticResource TextLightBrush}"/>
                        <TextBlock Text="45,230 ₽" FontSize="24" FontWeight="Bold" Foreground="{StaticResource BurgundyMainBrush}" Margin="0,5,0,0"/>
                        <TextBlock Text="Средний чек: 356 ₽" FontSize="10" Foreground="{StaticResource TextLightBrush}" Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Карточка 4 -->
                <Border Style="{StaticResource CardStyle}" Width="200" Height="100" Margin="0,0,15,15">
                    <StackPanel>
                        <TextBlock Text="Новых клиентов" FontSize="11" Foreground="{StaticResource TextLightBrush}"/>
                        <TextBlock Text="23" FontSize="28" FontWeight="Bold" Foreground="{StaticResource BurgundyMainBrush}" Margin="0,5,0,0"/>
                        <TextBlock Text="за сегодня" FontSize="10" Foreground="{StaticResource TextLightBrush}" Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>
            </WrapPanel>

            <!-- Быстрые действия -->
            <Border Style="{StaticResource CardStyle}" Margin="0,10,0,15" Height="94">
                <StackPanel>
                    <TextBlock Text="Быстрые действия" Style="{StaticResource SubHeaderTextStyle}" Margin="0,0,0,10"/>
                    <WrapPanel Orientation="Horizontal">
                        <Button Content="➕ Добавить новое блюдо" Style="{StaticResource BurgundyButtonStyle}" Margin="0,0,10,5" 
                                Click="AddNewDish_Click" Height="24"/>
                        <Button Content="🎯 Создать акцию" Style="{StaticResource BurgundyButtonStyle}" Margin="0,0,10,5" 
                                Click="CreatePromotion_Click"/>
                        <Button Content="📦 Просмотреть заказы" Style="{StaticResource BurgundyButtonStyle}" Margin="0,0,10,5" 
                                Click="ViewNewOrders_Click"/>
                        <Button Content="👥 Добавить сотрудника" Style="{StaticResource BurgundyButtonStyle}" Margin="0,0,10,5" 
                                Click="AddEmployee_Click"/>
                    </WrapPanel>
                </StackPanel>
            </Border>

            <!-- Последние заказы -->
            <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBlock Text="Последние заказы" Style="{StaticResource SubHeaderTextStyle}"/>
                        <TextBlock Text=" (сегодня)" Foreground="{StaticResource TextLightBrush}" FontSize="11" Margin="5,0,0,0" VerticalAlignment="Bottom"/>
                    </StackPanel>

                    <DataGrid x:Name="RecentOrdersGrid" Style="{StaticResource ModernDataGridStyle}" 
                              Height="220" AutoGenerateColumns="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="70"/>
                            <DataGridTextColumn Header="Клиент" Binding="{Binding CustomerName}" Width="150"/>
                            <DataGridTextColumn Header="Телефон" Binding="{Binding Phone}" Width="120"/>
                            <DataGridTextColumn Header="Сумма" Binding="{Binding TotalAmount}" Width="100"/>
                            <DataGridTextColumn Header="Статус" Binding="{Binding Status}" Width="120">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Center"/>
                                        <Setter Property="Padding" Value="5,2"/>
                                        <Setter Property="Background" Value="{StaticResource BeigeMediumBrush}"/>
                                        <Setter Property="Foreground" Value="{StaticResource BurgundyMainBrush}"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Время" Binding="{Binding OrderTime}" Width="100"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>