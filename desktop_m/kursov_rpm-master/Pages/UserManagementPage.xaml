<Page x:Class="RPM.UserManagementPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Сотрудники">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Заголовок и кнопка добавления -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15">
            <TextBlock Text="Управление сотрудниками" Style="{StaticResource HeaderTextStyle}"/>
            <Button Content="👥 Добавить сотрудника" Style="{StaticResource BurgundyButtonStyle}" 
                    Margin="20,0,0,0" Click="AddEmployee_Click"/>
        </StackPanel>

        <!-- Статистика сотрудников -->
        <WrapPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,15">
            <Border Style="{StaticResource CardStyle}" Width="180" Height="80" Margin="0,0,15,0">
                <StackPanel>
                    <TextBlock Text="Всего сотрудников" FontSize="11" Foreground="{StaticResource TextLightBrush}"/>
                    <TextBlock Text="15" FontSize="24" FontWeight="Bold" Foreground="{StaticResource BurgundyMainBrush}"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource CardStyle}" Width="180" Height="80" Margin="0,0,15,0">
                <StackPanel>
                    <TextBlock Text="Активных" FontSize="11" Foreground="{StaticResource TextLightBrush}"/>
                    <TextBlock Text="12" FontSize="24" FontWeight="Bold" Foreground="Green"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource CardStyle}" Width="180" Height="80">
                <StackPanel>
                    <TextBlock Text="В отпуске" FontSize="11" Foreground="{StaticResource TextLightBrush}"/>
                    <TextBlock Text="3" FontSize="24" FontWeight="Bold" Foreground="Orange"/>
                </StackPanel>
            </Border>
        </WrapPanel>

        <!-- Список сотрудников -->
        <Border Grid.Row="2" Style="{StaticResource CardStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                    <TextBlock Text="Список сотрудников" Style="{StaticResource SubHeaderTextStyle}"/>
                    <CheckBox x:Name="ActiveOnlyCheckBox" Content="Только активные" 
                              Margin="20,0,0,0" VerticalAlignment="Center"
                              Checked="ActiveOnlyCheckBox_Changed" Unchecked="ActiveOnlyCheckBox_Changed"/>
                </StackPanel>

                <DataGrid Grid.Row="1" x:Name="EmployeesGrid" Style="{StaticResource ModernDataGridStyle}"
                          AutoGenerateColumns="False">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                        <DataGridTextColumn Header="ФИО" Binding="{Binding FullName}" Width="150"/>
                        <DataGridTextColumn Header="Должность" Binding="{Binding Position}" Width="120"/>
                        <DataGridTextColumn Header="Телефон" Binding="{Binding Phone}" Width="120"/>
                        <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="150"/>
                        <DataGridTextColumn Header="Дата найма" Binding="{Binding HireDate, StringFormat={}{0:dd.MM.yy}}" Width="90"/>
                        <DataGridCheckBoxColumn Header="Активен" Binding="{Binding IsActive}" Width="60"/>
                        <DataGridTemplateColumn Header="Действия" Width="80">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <Button Content="✏️" ToolTip="Редактировать" 
                                                Click="EditEmployee_Click" Margin="2" Padding="5"
                                                Background="Transparent" BorderThickness="0"/>
                                        <Button Content="❌" ToolTip="Удалить" 
                                                Click="DeleteEmployee_Click" Margin="2" Padding="5"
                                                Background="Transparent" BorderThickness="0"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
    </Grid>
</Page>