<UserControl x:Class="RPM.Pages.MenuView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             mc:Ignorable="d"
             d:DesignHeight="500" d:DesignWidth="800">
	<UserControl.Resources>

		<!-- Стиль текстбокса с закруглением и кастомным placeholder -->
		<Style x:Key="RoundedSearchBox" TargetType="TextBox">
			<Setter Property="Background" Value="White"/>
			<Setter Property="BorderBrush" Value="#FFBFAE9F"/>
			<Setter Property="BorderThickness" Value="1"/>
			<Setter Property="Padding" Value="8,0"/>
			<Setter Property="Foreground" Value="Black"/>

			<Setter Property="Template">
				<Setter.Value>
					<ControlTemplate TargetType="TextBox">
						<Grid>
							<!-- Основной фон с закруглением -->
							<Border x:Name="Border"
                                CornerRadius="15"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"/>

							<!-- Текст -->
							<ScrollViewer x:Name="PART_ContentHost"
                                      Margin="{TemplateBinding Padding}"/>

							<!-- Placeholder -->
							<TextBlock x:Name="PlaceholderText"
                                   Text="Поиск по блюдам..."
                                   Margin="17,0,0,0"
                                   VerticalAlignment="Center"
                                   Foreground="#888"
                                   IsHitTestVisible="False"
                                   Visibility="Collapsed"/>
						</Grid>

						<ControlTemplate.Triggers>

							<!-- Показать placeholder если текст пуст -->
							<Trigger Property="Text" Value="">
								<Setter TargetName="PlaceholderText" Property="Visibility" Value="Visible"/>
							</Trigger>

							<!-- Подсветка при фокусе -->
							<Trigger Property="IsKeyboardFocused" Value="True">
								<Setter TargetName="Border" Property="BorderBrush" Value="#FFB07D62"/>
								<Setter TargetName="Border" Property="BorderThickness" Value="2"/>
							</Trigger>

						</ControlTemplate.Triggers>
					</ControlTemplate>
				</Setter.Value>
			</Setter>
		</Style>

	</UserControl.Resources>

	<Grid Margin="20">

		<!-- Верхняя панель: Название + поиск -->
		<StackPanel Orientation="Vertical">
			<DockPanel Margin="0,0,0,10">
				<TextBlock Text="Меню" FontSize="28" FontWeight="Bold" DockPanel.Dock="Left" VerticalAlignment="Center"/>

				<!-- Поиск справа -->
				<Grid Width="300" Height="30" Margin="20,0,0,0" DockPanel.Dock="Right">
					<TextBox x:Name="SearchBox"
						 Style="{StaticResource RoundedSearchBox}"
						 Height="30"
						 VerticalContentAlignment="Center"
						 TextChanged="SearchBox_TextChanged"/>


					<!-- Placeholder -->
					<TextBlock Foreground="Gray" Margin="5,0,0,0"
                   VerticalAlignment="Center"
                   IsHitTestVisible="False"
                   Visibility="{Binding Text, ElementName=SearchBox, Converter={StaticResource StringNullOrEmptyToVisibilityConverter}}"/>
				</Grid>
			</DockPanel>


			<Border Background="#FFF1D8" 
					CornerRadius="10"
					Height="40">
				<!-- Сегментированный фильтр по категориям -->
				<ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled" Height="40">
					<StackPanel x:Name="CategoryPanel" Orientation="Horizontal" HorizontalAlignment="Left" 
					VerticalAlignment="Center"/>
				</ScrollViewer>
			</Border>
		</StackPanel>

		<!-- Контент: карточки блюд -->
		<ScrollViewer Grid.Row="1" Margin="0,100,0,0">
			<ItemsControl x:Name="ItemsControlMenu">
				<ItemsControl.ItemsPanel>
					<ItemsPanelTemplate>
						<WrapPanel IsItemsHost="True"/>
					</ItemsPanelTemplate>
				</ItemsControl.ItemsPanel>

				<ItemsControl.ItemTemplate>
					<DataTemplate>
						<Border BorderBrush="Gray" BorderThickness="1" Margin="5" Padding="5" Width="200" CornerRadius="8">
							<StackPanel Orientation="Vertical">
								<Image Source="{Binding ImageURL}" Width="180" Height="140" Stretch="UniformToFill"/>
								<TextBlock Text="{Binding Name}" FontWeight="Bold" Margin="0,5,0,0"/>
								<TextBlock Text="{Binding Description}" TextWrapping="Wrap" Height="60"/>
								<TextBlock Text="{Binding Price}" Foreground="Green" Margin="0,5,0,0"/>

								<StackPanel Orientation="Vertical" VerticalAlignment="Center" Margin="0,5,0,0">
									<Button Content="Редактировать" Width="150" Height="25" Margin="5"
                                            Click="EditItem_Click" HorizontalContentAlignment="Center"/>
									<Button Content="Удалить" Width="150" Height="25" Click="DeleteItem_Click"
                                            VerticalContentAlignment="Center" HorizontalContentAlignment="Center"/>
								</StackPanel>
							</StackPanel>
						</Border>
					</DataTemplate>
				</ItemsControl.ItemTemplate>
			</ItemsControl>
		</ScrollViewer>
	</Grid>
</UserControl>
