<Window x:Class="RPM.UsersEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Редактирование сотрудника" Height="300" Width="400"
        WindowStartupLocation="CenterScreen">
	<Grid Margin="20">
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
		</Grid.RowDefinitions>

		<TextBlock Text="ФИО:"
		Grid.Row="0"/>
		<TextBox x:Name="FullNameTextBox" 
		Grid.Row="1"/>

		<TextBlock Text="Логин:" Grid.Row="2" />
		<TextBox x:Name="LoginTextBox" 
					Grid.Row="3"/>

		<TextBlock Text="Роль:" Grid.Row="4"  />
		<ComboBox x:Name="PositionCombo" Grid.Row="5"  />
		<TextBlock x:Name="RoleErrorText"
           Grid.Row="6"
           Text="Выберите роль"
           Foreground="#E84C34"
           FontSize="13"
           Margin="5,4,0,0"
           Visibility="Collapsed"/>

		<StackPanel Orientation="Horizontal" Grid.Row="7" HorizontalAlignment="Right" Margin="0,20,0,0">
			<Button Content="Сохранить" Width="100" Margin="10,0,0,0" Click="SaveButton_Click"/>
			<Button Content="Отмена" Width="100" Margin="10,0,0,0" Click="CancelButton_Click"/>
		</StackPanel>
	</Grid>
	<Window.Resources>
		<Style x:Key="ErrorComboStyle" TargetType="ComboBox" BasedOn="{StaticResource {x:Type ComboBox}}">
			<Setter Property="BorderBrush" Value="#E84C34"/>
			<Setter Property="BorderThickness" Value="2"/>
		</Style>
	</Window.Resources>

</Window>
