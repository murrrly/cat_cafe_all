<Window x:Class="RPM.PromotionEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Создать акцию" Height="500" Width="500"
        WindowStartupLocation="CenterScreen">
	<Grid Margin="20">
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="*"/>
			<RowDefinition Height="Auto"/>
		</Grid.RowDefinitions>

		<TextBlock Text="Название:"/>
		<TextBox x:Name="NameTextBox" Grid.Row="0" Margin="0,25,0,0"/>

		<TextBlock Text="Описание:" Grid.Row="1" Margin="0,10,0,0"/>
		<TextBox x:Name="DescriptionTextBox" Grid.Row="1" Margin="0,35,0,0"/>

		<StackPanel Orientation="Horizontal" Grid.Row="2" Margin="0,10,0,0">
			<StackPanel>
				<TextBlock Text="Дата начала:"/>
				<DatePicker x:Name="StartDatePicker"/>
			</StackPanel>
			<StackPanel Margin="20,0,0,0">
				<TextBlock Text="Дата окончания:"/>
				<DatePicker x:Name="EndDatePicker"/>
			</StackPanel>
		</StackPanel>

		<StackPanel Grid.Row="3" Margin="0,10,0,0">
			<TextBlock Text="Блюда в акции:"/>
			<ListBox x:Name="MenuListBox" SelectionMode="Extended" Height="150"/>
			<TextBlock Text="Цена по акции:" Margin="0,10,0,0"/>
			<TextBox x:Name="DiscountPriceTextBox"/>
		</StackPanel>

		<StackPanel Orientation="Horizontal" Grid.Row="4" HorizontalAlignment="Right" Margin="0,20,0,0">
			<Button Content="Сохранить" Width="100" Click="SaveButton_Click"/>
			<Button Content="Отмена" Width="100" Margin="10,0,0,0" Click="CancelButton_Click"/>
		</StackPanel>
	</Grid>
</Window>
