<Window x:Class="RPM.AdvertisementEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Добавить рекламу" Height="400" Width="400"
        WindowStartupLocation="CenterScreen">
	<Grid Margin="20">
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="*"/>
		</Grid.RowDefinitions>

		<TextBlock Text="Заголовок:"/>
		<TextBox x:Name="TitleTextBox" Grid.Row="0" Margin="0,25,0,0"/>

		<TextBlock Text="Описание:" Grid.Row="1" Margin="0,10,0,0"/>
		<TextBox x:Name="DescriptionTextBox" Grid.Row="1" Margin="0,35,0,0"/>

		<TextBlock Text="URL картинки:" Grid.Row="2" Margin="0,10,0,0"/>
		<TextBox x:Name="ImageUrlTextBox" Grid.Row="2" Margin="0,35,0,0"/>

		<StackPanel Orientation="Horizontal" Grid.Row="3" Margin="0,10,0,0">
			<TextBlock Text="Активна:" VerticalAlignment="Center" Margin="0,0,10,0"/>
			<CheckBox x:Name="IsActiveCheckBox" IsChecked="True" VerticalAlignment="Center"/>
		</StackPanel>

		<StackPanel Orientation="Horizontal" Grid.Row="4" HorizontalAlignment="Right" Margin="0,20,0,0">
			<Button Content="Сохранить" Width="100" Click="SaveButton_Click"/>
			<Button Content="Отмена" Width="100" Margin="10,0,0,0" Click="CancelButton_Click"/>
		</StackPanel>
	</Grid>
</Window>
