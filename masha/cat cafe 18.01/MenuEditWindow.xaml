<Window x:Class="RPM.MenuEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Редактирование блюда" Height="400" Width="400" MinHeight="400"
        WindowStartupLocation="CenterScreen">
	<Window.Resources>

		<!-- Общий стиль TextBox -->
		<Style x:Key="RoundedTextBox" TargetType="TextBox">
			<Setter Property="Height" Value="30"/>
			<Setter Property="Padding" Value="8,0"/>
			<Setter Property="Background" Value="White"/>
			<Setter Property="BorderBrush" Value="#FFBFAE9F"/>
			<Setter Property="BorderThickness" Value="1"/>
			<Setter Property="VerticalContentAlignment" Value="Center"/>

			<Setter Property="Template">
				<Setter.Value>
					<ControlTemplate TargetType="TextBox">
						<Border x:Name="Border"
                            CornerRadius="10"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}">
							<ScrollViewer x:Name="PART_ContentHost"
                                      Padding="{TemplateBinding Padding}"/>
						</Border>

						<ControlTemplate.Triggers>
							<Trigger Property="IsKeyboardFocused" Value="True">
								<Setter TargetName="Border" Property="BorderBrush" Value="#FFB07D62"/>
								<Setter TargetName="Border" Property="BorderThickness" Value="2"/>
							</Trigger>
						</ControlTemplate.Triggers>
					</ControlTemplate>
				</Setter.Value>
			</Setter>
		</Style>

		<!-- Кнопки -->
		<Style x:Key="PrimaryButton" TargetType="Button">
			<Setter Property="Height" Value="32"/>
			<Setter Property="Padding" Value="16,4"/>
			<Setter Property="Background" Value="#FFD7A888"/>
			<Setter Property="Foreground" Value="#4A2E1A"/>
			<Setter Property="BorderBrush" Value="Transparent"/>
			<Setter Property="Cursor" Value="Hand"/>

			<Setter Property="Template">
				<Setter.Value>
					<ControlTemplate TargetType="Button">
						<Border x:Name="Border"
                            CornerRadius="14"
                            Background="{TemplateBinding Background}">
							<ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
						</Border>

						<ControlTemplate.Triggers>
							<Trigger Property="IsMouseOver" Value="True">
								<Setter TargetName="Border" Property="Background" Value="#FFCFA27C"/>
							</Trigger>
							<Trigger Property="IsPressed" Value="True">
								<Setter TargetName="Border" Property="Background" Value="#FFB88963"/>
							</Trigger>
						</ControlTemplate.Triggers>
					</ControlTemplate>
				</Setter.Value>
			</Setter>
		</Style>

	</Window.Resources>
	<Border Background="#FFFFF4EA"
        CornerRadius="20"
        Padding="0,0">

		<Grid Margin="20">
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="7*"/>
				<ColumnDefinition Width="25*"/>
			</Grid.ColumnDefinitions>
			<Grid.RowDefinitions>
				<RowDefinition Height="Auto"/>
				<RowDefinition Height="Auto"/>
				<RowDefinition Height="Auto"/>
				<RowDefinition Height="Auto"/>
				<RowDefinition Height="*"/>
			</Grid.RowDefinitions>

			<TextBlock Text="Название:" Grid.ColumnSpan="2"/>
			<TextBox x:Name="NameTextBox" Grid.Row="0" Margin="0,25,0,0" 
				 Style="{StaticResource RoundedTextBox}" Grid.ColumnSpan="2"/>

			<TextBlock Text="Состав:" Grid.Row="1" Margin="0,10,0,0" Grid.ColumnSpan="2"/>
			<TextBox x:Name="CompositionTextBox" Grid.Row="1" Margin="0,35,0,0"
         Style="{StaticResource RoundedTextBox}" Grid.ColumnSpan="2"/>

			<TextBlock Text="Описание:" Grid.Row="2" Margin="0,10,0,0" Grid.ColumnSpan="2"/>
			<TextBox x:Name="DescriptionTextBox" Grid.Row="2" Margin="0,35,0,0"
         Style="{StaticResource RoundedTextBox}" Grid.ColumnSpan="2"/>

			<TextBlock Text="Цена:" Grid.Row="3" Margin="0,10,0,0" Grid.ColumnSpan="2"/>
			<TextBox x:Name="PriceTextBox" Grid.Row="3" Margin="0,35,0,0"
         Style="{StaticResource RoundedTextBox}" Grid.ColumnSpan="2"/>

			<StackPanel Orientation="Horizontal" Grid.Row="4" HorizontalAlignment="Right" Margin="0,15,0,0" Grid.Column="1">
				<Button Content="Сохранить" Width="100" Margin="10,0,0,0" Click="SaveButton_Click"/>
				<Button Content="Отмена" Width="100" Margin="10,0,0,0" Click="CancelButton_Click"/>
			</StackPanel>
		</Grid>
	</Border>
</Window>
