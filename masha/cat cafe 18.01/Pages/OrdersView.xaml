<UserControl x:Class="RPM.Pages.OrdersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:converters="clr-namespace:RPM.Converters"
             mc:Ignorable="d"
             d:DesignHeight="500" d:DesignWidth="800">

	<UserControl.Resources>
		<converters:ShortNameConverter x:Key="ShortNameConverter"/>
	</UserControl.Resources>

	<Grid Margin="20">
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="*"/>
		</Grid.RowDefinitions>

		<StackPanel Grid.Row="0">
			<TextBlock Text="Список заказов" FontSize="28" Margin="0,0,0,20"/>
			<Button Content="Обновить" Width="120" Height="40" HorizontalAlignment="Left" Click="RefreshButton_Click" Margin="0,0,0,10"/>
		</StackPanel>

		<ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
			<ItemsControl x:Name="OrdersItemsControl" ItemsSource="{Binding Orders}">
				<ItemsControl.ItemsPanel>
					<ItemsPanelTemplate>
						<WrapPanel IsItemsHost="True" Orientation="Horizontal"/>
					</ItemsPanelTemplate>
				</ItemsControl.ItemsPanel>

				<ItemsControl.ItemTemplate>
					<DataTemplate>
						<Border CornerRadius="14"
            Margin="10"
            Padding="0"
            Background="#FFF1D8"
            BorderBrush="Brown"
            BorderThickness="1"
            MinWidth="260"
            MaxWidth="340">

							<Grid>
								<Grid.RowDefinitions>
									<RowDefinition Height="Auto"/>
									<RowDefinition Height="*"/>
									<RowDefinition Height="Auto"/>
								</Grid.RowDefinitions>

								<!-- ===== ВЕРХНЯЯ ПАНЕЛЬ ===== -->
								<Border Background="#FFE8C2"
                    CornerRadius="14,14,0,0"
                    Padding="12">
									<Grid>
										<Grid.ColumnDefinitions>
											<ColumnDefinition Width="*"/>
											<ColumnDefinition Width="Auto"/>
										</Grid.ColumnDefinitions>

										<!-- Номер заказа -->
										<TextBlock Text="{Binding OrderNumber}"
                               FontSize="16"
                               FontWeight="Bold"/>

										<!-- Дата -->
										<TextBlock Text="{Binding OrderDate, StringFormat={}{0:HH:mm dd.MM}}"
                               Grid.Column="1"
                               VerticalAlignment="Center"
                               Opacity="0.8"/>
									</Grid>
								</Border>

								<!-- ===== СЕРЕДИНА (позиции + кассир) ===== -->
								<StackPanel Grid.Row="1"  >

									<!-- Кассир -->
									<TextBlock Text="{Binding CashierName, Converter={StaticResource ShortNameConverter}}"
                           FontSize="12"
                           Opacity="0.7"
                           Margin="0,0,0,6"/>

									<!-- Список позиций -->
									<ItemsControl ItemsSource="{Binding Items}">
										<ItemsControl.ItemTemplate>
											<DataTemplate>
												<Grid Margin="0,2">
													<Grid.ColumnDefinitions>
														<ColumnDefinition Width="*"/>
														<ColumnDefinition Width="40"/>
														<ColumnDefinition Width="70"/>
													</Grid.ColumnDefinitions>

													<TextBlock Text="{Binding MenuName}"
                                           TextTrimming="CharacterEllipsis"/>

													<TextBlock Text="{Binding Quantity}"
                                           Grid.Column="1"
                                           HorizontalAlignment="Center"
                                           Opacity="0.8"/>

													<TextBlock Text="{Binding UnitPrice, StringFormat={}{0:N0}}"
                                           Grid.Column="2"
                                           HorizontalAlignment="Right"/>
												</Grid>
											</DataTemplate>
										</ItemsControl.ItemTemplate>
									</ItemsControl>
								</StackPanel>

								<!-- ===== НИЗ (итог и оплата) ===== -->
								<Border Grid.Row="2"
                    Background="#FFE8C2"
                    CornerRadius="0,0,14,14"
                    Padding="12">
									<Grid>
										<Grid.ColumnDefinitions>
											<ColumnDefinition Width="*"/>
											<ColumnDefinition Width="Auto"/>
										</Grid.ColumnDefinitions>

										<!-- Сумма -->
										<StackPanel>
											<TextBlock Text="ИТОГО"
                                   FontSize="11"
                                   Opacity="0.6"/>
											<TextBlock Text="{Binding TotalAmount, StringFormat={}{0:N0}}"
                                   FontSize="18"
                                   FontWeight="Bold"/>
										</StackPanel>

										<!-- Способ оплаты как бейдж -->
										<Border Grid.Column="1"
                            Background="#FFD8A86B"
                            Padding="8,3"
                            CornerRadius="10"
                            VerticalAlignment="Center">
											<TextBlock Text="{Binding PaymentType}"
                                   FontSize="12"
                                   FontWeight="SemiBold"/>
										</Border>
									</Grid>
								</Border>

							</Grid>
						</Border>
					</DataTemplate>

				</ItemsControl.ItemTemplate>
			</ItemsControl>
		</ScrollViewer>
	</Grid>
</UserControl>
