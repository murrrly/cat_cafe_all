<UserControl x:Class="RPM.Pages.OrdersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:converters="clr-namespace:RPM.Converters"
             mc:Ignorable="d"
             d:DesignHeight="500" d:DesignWidth="800">

	<UserControl.Resources>
		<converters:ShortNameConverter x:Key="ShortNameConverter"/>

		<Style TargetType="ComboBox" x:Key="BranchComboBoxStyle">
			<!-- здесь вставляем весь стиль ComboBox, который я присылала ранее -->
		</Style>
	</UserControl.Resources>

	<Grid Margin="20">
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="*"/>
		</Grid.RowDefinitions>

		<!-- ВЕРХ: Заголовок + кнопка и выбор филиала -->
		<StackPanel Grid.Row="0" Orientation="Vertical" Margin="0,0,0,20">

			<!-- Заголовок -->
			<TextBlock Text="Список заказов" FontSize="28" FontWeight="Bold" Margin="0,0,0,10"/>

			<!-- Панель кнопки и ComboBox -->
			<Grid>
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="*"/>
					<!-- пустое пространство слева -->
					<ColumnDefinition Width="Auto"/>
					<!-- Кнопка -->
					<ColumnDefinition Width="Auto"/>
					<!-- ComboBox -->
				</Grid.ColumnDefinitions>

				<!-- Кнопка Обновить -->
				<Button Content="Обновить"
                        Width="120"
                        Height="40"
                        Grid.Column="1"
                        Margin="0,0,10,0"
                        Click="RefreshButton_Click"/>

				<!-- ComboBox филиала справа -->
				<ComboBox x:Name="BranchComboBox"
						  Width="200"
						  Height="30"
						  DisplayMemberPath="Address"  
						SelectedValuePath="ID" 
						ItemsSource="{Binding Branches}"
						Grid.Column="2"
						SelectionChanged="BranchComboBox_SelectionChanged"/>


			</Grid>
		</StackPanel>

		<!-- Список заказов -->
		<ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
			<ItemsControl x:Name="OrdersItemsControl" ItemsSource="{Binding Orders}">
				<ItemsControl.ItemsPanel>
					<ItemsPanelTemplate>
						<WrapPanel IsItemsHost="True" Orientation="Horizontal"/>
					</ItemsPanelTemplate>
				</ItemsControl.ItemsPanel>

				<ItemsControl.ItemContainerStyle>
					<Style TargetType="ContentPresenter">
						<Setter Property="Width" Value="320"/>
						<Setter Property="Margin" Value="10"/>
					</Style>
				</ItemsControl.ItemContainerStyle>

				<!-- Карточка заказа -->
				<ItemsControl.ItemTemplate>
					<DataTemplate>
						<Border CornerRadius="14"
                                Background="#FFF1D8"
                                BorderBrush="Brown"
                                BorderThickness="1"
                                MinWidth="260"
                                MaxWidth="340">

							<Grid>
								<Grid.RowDefinitions>
									<RowDefinition Height="Auto"/>
									<RowDefinition Height="*"/>
									<RowDefinition Height="Auto"/>
								</Grid.RowDefinitions>

								<!-- Верх: номер и дата -->
								<Border Background="#FFE8C2"
                                        CornerRadius="14,14,0,0"
                                        Padding="12">
									<Grid>
										<Grid.ColumnDefinitions>
											<ColumnDefinition Width="*"/>
											<ColumnDefinition Width="Auto"/>
										</Grid.ColumnDefinitions>

										<TextBlock Text="{Binding OrderNumber}"
                                                   FontSize="16"
                                                   FontWeight="Bold"/>
										<TextBlock Text="{Binding OrderDate, StringFormat={}{0:HH:mm dd.MM}}"
                                                   Grid.Column="1"
                                                   VerticalAlignment="Center"
                                                   Opacity="0.8"/>
									</Grid>
								</Border>

								<!-- Середина: кассир + позиции -->
								<Border Grid.Row="1" Padding="12,10">
									<StackPanel>
										<TextBlock Text="{Binding CashierName, Converter={StaticResource ShortNameConverter}}"
                                                   FontSize="12"
                                                   Opacity="0.7"
                                                   Margin="0,0,0,6"/>
										<ItemsControl ItemsSource="{Binding Items}">
											<ItemsControl.ItemTemplate>
												<DataTemplate>
													<Grid Margin="0,2">
														<Grid.ColumnDefinitions>
															<ColumnDefinition Width="*"/>
															<ColumnDefinition Width="40"/>
															<ColumnDefinition Width="70"/>
														</Grid.ColumnDefinitions>

														<TextBlock Text="{Binding MenuName}"
                                                                   TextTrimming="CharacterEllipsis"/>
														<TextBlock Text="{Binding Quantity}"
                                                                   Grid.Column="1"
                                                                   HorizontalAlignment="Center"
                                                                   Opacity="0.8"/>
														<TextBlock Text="{Binding UnitPrice, StringFormat={}{0:N0}}"
                                                                   Grid.Column="2"
                                                                   HorizontalAlignment="Right"/>
													</Grid>
												</DataTemplate>
											</ItemsControl.ItemTemplate>
										</ItemsControl>
									</StackPanel>
								</Border>

								<!-- Низ: Итого и способ оплаты -->
								<Border Grid.Row="2"
                                        Background="#FFE8C2"
                                        CornerRadius="0,0,14,14"
                                        Padding="12">
									<Grid>
										<Grid.ColumnDefinitions>
											<ColumnDefinition Width="*"/>
											<ColumnDefinition Width="Auto"/>
										</Grid.ColumnDefinitions>

										<StackPanel>
											<TextBlock Text="ИТОГО"
                                                       FontSize="11"
                                                       Opacity="0.6"/>
											<TextBlock Text="{Binding TotalAmount, StringFormat={}{0:N0}}"
                                                       FontSize="18"
                                                       FontWeight="Bold"/>
										</StackPanel>

										<Border Grid.Column="1"
                                                Background="#FFD8A86B"
                                                Padding="8,3"
                                                CornerRadius="10"
                                                VerticalAlignment="Center">
											<TextBlock Text="{Binding PaymentType}"
                                                       FontSize="12"
                                                       FontWeight="SemiBold"/>
										</Border>
									</Grid>
								</Border>
							</Grid>
						</Border>
					</DataTemplate>
				</ItemsControl.ItemTemplate>
			</ItemsControl>
		</ScrollViewer>
	</Grid>
</UserControl>
