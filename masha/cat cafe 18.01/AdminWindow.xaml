<Window x:Class="RPM.AdminWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Администратор" Height="700" Width="1100"
        WindowStartupLocation="CenterScreen">

	<Grid>
		<Grid.ColumnDefinitions>
			<ColumnDefinition Width="220"/>
			<ColumnDefinition Width="*"/>
		</Grid.ColumnDefinitions>

		<!-- ЛЕВАЯ ПАНЕЛЬ -->
		<Border Background="#2D2D30">
			<StackPanel Margin="10">

				<TextBlock Text="АДМИН-ПАНЕЛЬ"
                           Foreground="White"
                           FontSize="20"
                           Margin="0,10,0,30"
                           HorizontalAlignment="Center"/>

				<Button Content="Заказы" Height="45" Margin="0,5"
                        Click="Orders_Click"/>

				<Button Content="Меню" Height="45" Margin="0,5"
                        Click="Menu_Click"/>

				<Button Content="Сотрудники" Height="45" Margin="0,5"
                        Click="Users_Click"/>

				<Button Content="Статистика" Height="45" Margin="0,5"
                        Click="Stats_Click"/>

				<Button Content="Акции" Height="45" Margin="0,5"
                        Click="Promo_Click"/>

				<Button Content="Выход" Height="40" Margin="0,40,0,0"
                        Background="#AA3333" Foreground="White"
                        Click="Exit_Click"/>
			</StackPanel>
		</Border>

		<!-- ПРАВАЯ ОБЛАСТЬ -->
		<Border Grid.Column="1" Background="#F5F5F5">
			<ContentControl x:Name="MainContent"/>
		</Border>

	</Grid>
</Window>
