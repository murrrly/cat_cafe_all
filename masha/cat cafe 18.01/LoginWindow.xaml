<Window x:Class="RPM.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Авторизация - Sushi Cats Cafe" 
        Height="600" Width="800"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

	<Window.Resources>
		<!-- Стили для текста -->
		<Style x:Key="BalooFontStyle" TargetType="TextBlock">
			<Setter Property="FontFamily" Value="Baloo Paaji 2"/>
			<Setter Property="Foreground" Value="White"/>
			<Setter Property="VerticalAlignment" Value="Center"/>
		</Style>

		<Style x:Key="BlackBalooFontStyle" TargetType="TextBlock">
			<Setter Property="FontFamily" Value="Baloo Paaji 2"/>
			<Setter Property="Foreground" Value="Black"/>
			<Setter Property="VerticalAlignment" Value="Center"/>
		</Style>

		<!-- Стиль для TextBox с placeholder -->
		<Style x:Key="PlaceholderTextBoxStyle" TargetType="TextBox">
			<Setter Property="Background" Value="Transparent"/>
			<Setter Property="BorderBrush" Value="Transparent"/>
			<Setter Property="Foreground" Value="#5F5F5F"/>
			<Setter Property="FontFamily" Value="Baloo Paaji 2"/>
			<Setter Property="FontSize" Value="24"/>
			<Setter Property="VerticalContentAlignment" Value="Center"/>
			<Setter Property="Template">
				<Setter.Value>
					<ControlTemplate TargetType="TextBox">
						<Grid>
							<ScrollViewer x:Name="PART_ContentHost" 
                                        VerticalAlignment="Center"
                                        Margin="0,0,0,3"/>
							<Rectangle Height="2" 
                                     Fill="White"
                                     VerticalAlignment="Bottom"
                                     Margin="0,0,0,-3"/>
						</Grid>
					</ControlTemplate>
				</Setter.Value>
			</Setter>
		</Style>

		<!-- Стиль для PasswordBox с placeholder -->
		<Style x:Key="PlaceholderPasswordBoxStyle" TargetType="PasswordBox">
			<Setter Property="Background" Value="Transparent"/>
			<Setter Property="BorderBrush" Value="Transparent"/>
			<Setter Property="Foreground" Value="#5F5F5F"/>
			<Setter Property="FontFamily" Value="Baloo Paaji 2"/>
			<Setter Property="FontSize" Value="24"/>
			<Setter Property="VerticalContentAlignment" Value="Center"/>
			<Setter Property="Template">
				<Setter.Value>
					<ControlTemplate TargetType="PasswordBox">
						<Grid>
							<ScrollViewer x:Name="PART_ContentHost" 
                                        VerticalAlignment="Center"
                                        Margin="0,0,0,3"/>
							<Rectangle Height="2" 
                                     Fill="White"
                                     VerticalAlignment="Bottom"
                                     Margin="0,0,0,-3"/>
						</Grid>
					</ControlTemplate>
				</Setter.Value>
			</Setter>
		</Style>

		<!-- Стиль для кнопки входа -->
		<Style x:Key="EnterButtonStyle" TargetType="Button">
			<Setter Property="Background" Value="Transparent"/>
			<Setter Property="BorderBrush" Value="Transparent"/>
			<Setter Property="Foreground" Value="White"/>
			<Setter Property="FontFamily" Value="Baloo Paaji 2"/>
			<Setter Property="FontSize" Value="28"/>
			<Setter Property="Cursor" Value="Hand"/>
			<Setter Property="Template">
				<Setter.Value>
					<ControlTemplate TargetType="Button">
						<Border Background="Transparent">
							<ContentPresenter Content="{TemplateBinding Content}"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
						</Border>
					</ControlTemplate>
				</Setter.Value>
			</Setter>
		</Style>
	</Window.Resources>

	<Grid>
		<!-- Фоновое изображение -->
		<Grid.Background>
			<ImageBrush ImageSource="images/fon.jpg" Stretch="UniformToFill">
				<ImageBrush.Transform>
					<ScaleTransform ScaleX="1.1" ScaleY="1.1"/>
				</ImageBrush.Transform>
			</ImageBrush>
		</Grid.Background>

		<!-- Полупрозрачный красный оверлей -->
		<Rectangle>
			<Rectangle.Fill>
				<SolidColorBrush Color="#610606" Opacity="0.32"/>
			</Rectangle.Fill>
		</Rectangle>

		<!-- Заголовок приложения -->
		<TextBlock Text="Sushi Cats Cafe" 
                   FontFamily="Inter"
                   FontSize="16"
                   FontWeight="SemiBold"
                   Foreground="Black"
                   VerticalAlignment="Top"
                   HorizontalAlignment="Left"
                   Margin="12,12,0,0" />


		<!-- ПРЯМОУГОЛЬНИК С РАЗМЫТИЕМ -->
		<Border Width="560" Height="400"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="#80FFFFFF" 
                BorderThickness="2"
                CornerRadius="2">
			<Border.Effect>
				<BlurEffect Radius="20"/>
			</Border.Effect>
		</Border>



		<!-- Основной контейнер для текста -->
		<!-- Основной контейнер для текста -->
		<Grid Width="560" Height="400" HorizontalAlignment="Center" VerticalAlignment="Center">

			<!-- Заголовок формы -->
			<TextBlock Text="ВХОД В СИСТЕМУ" 
               Style="{StaticResource BalooFontStyle}"
               FontSize="36"
               HorizontalAlignment="Center"
               VerticalAlignment="Top"
               Margin="0,40,0,0"/>

			<!-- Контейнер для полей ввода -->
			<Grid VerticalAlignment="Center" HorizontalAlignment="Center" Width="450">
				<Grid.RowDefinitions>
					<RowDefinition Height="Auto"/>
					<RowDefinition Height="Auto"/>
				</Grid.RowDefinitions>
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="Auto"/>
					<ColumnDefinition Width="*"/>
				</Grid.ColumnDefinitions>

				<!-- Логин -->
				<TextBlock Text="Логин:" 
                   Style="{StaticResource BalooFontStyle}"
                   FontSize="32"
                   VerticalAlignment="Center"
                   Grid.Row="0" Grid.Column="0" Margin="0,0,10,0"/>
				<TextBox x:Name="UsernameTextBox" 
                 Style="{StaticResource PlaceholderTextBoxStyle}"
                 Height="45"
                 VerticalAlignment="Center"
                 Grid.Row="0" Grid.Column="1"
                 GotFocus="UsernameTextBox_GotFocus"
                 LostFocus="UsernameTextBox_LostFocus"/>

				<!-- Пароль -->
				<TextBlock Text="Пароль:" 
                   Style="{StaticResource BalooFontStyle}"
                   FontSize="32"
                   VerticalAlignment="Center"
                   Grid.Row="1" Grid.Column="0" Margin="0,10,10,0"/>
				<PasswordBox x:Name="PasswordBox" 
                     Style="{StaticResource PlaceholderPasswordBoxStyle}"
                     Height="45"
                     VerticalAlignment="Center"
                     Grid.Row="1" Grid.Column="1" Margin="0,10,0,0"
                     PasswordChar="•"
                     GotFocus="PasswordBox_GotFocus"
                     LostFocus="PasswordBox_LostFocus"/>
			</Grid>

			<!-- Нижняя панель с кнопками -->
			<Grid VerticalAlignment="Bottom" Height="80" Margin="0,0,0,20">
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="*"/>
					<ColumnDefinition Width="*"/>
				</Grid.ColumnDefinitions>

				<!-- Кнопка выхода слева -->
				<StackPanel Grid.Column="0" HorizontalAlignment="Right" VerticalAlignment="Center">
					<Button x:Name="ExitButton"
                    Content="Выход"
                    Style="{StaticResource EnterButtonStyle}"
                    Click="ExitButton_Click"/>
					<Rectangle Width="150" Height="2" Fill="#ED442A" HorizontalAlignment="Right" Margin="0,5,0,0"/>
				</StackPanel>

				<!-- Кнопка входа справа -->
				<StackPanel Grid.Column="1" HorizontalAlignment="Left" VerticalAlignment="Center">
					<Button x:Name="LoginButton"
                    Content="Вход"
                    Style="{StaticResource EnterButtonStyle}"
                    Click="LoginButton_Click">
						<Button.ToolTip>
							<ToolTip>
								<TextBlock Text="Логин: admin, Пароль: admin" Foreground="Black" Background="White"/>
							</ToolTip>
						</Button.ToolTip>
					</Button>
					<Rectangle Width="150" Height="2" Fill="#ED442A" HorizontalAlignment="Left" Margin="0,5,0,0"/>
				</StackPanel>
			</Grid>

			<!-- Сообщение об ошибке -->
			<TextBlock x:Name="ErrorText" 
               Text="" 
               Foreground="Red" 
               FontSize="12"
               HorizontalAlignment="Center"
               VerticalAlignment="Bottom"
               Margin="0,0,0,100"
               Visibility="Collapsed"/>
		</Grid>

	</Grid>
</Window>