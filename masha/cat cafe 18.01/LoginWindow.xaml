<Window x:Class="RPM.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Авторизация - FastFood Admin" 
        Height="531" Width="400"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="{StaticResource BeigeLightBrush}">

    <Grid Margin="0,0,0,12">
        <Border Style="{StaticResource CardStyle}" Margin="40,40,40,23" Background="White">
            <StackPanel Margin="25" VerticalAlignment="Center">
                <!-- Логотип -->
				<StackPanel HorizontalAlignment="Center" Margin="0,0,0,30">
					<TextBlock Text="FastFood Admin" FontSize="20" FontWeight="Bold" 
                              Foreground="{StaticResource BurgundyMainBrush}" 
                              HorizontalAlignment="Center" Margin="0,5,0,0"/>
                    <TextBlock Text="Панель управления" FontSize="12" 
                              Foreground="{StaticResource TextLightBrush}" 
                              HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- Поля ввода -->
                <TextBlock Text="Логин" FontWeight="SemiBold" Margin="0,10,0,5"
                          Foreground="{StaticResource TextDarkBrush}"/>
                <TextBox x:Name="UsernameTextBox" Height="40" Padding="10" 
                        Text="admin"
                        BorderBrush="{StaticResource BeigeDarkBrush}"
                        GotFocus="UsernameTextBox_GotFocus"
                        LostFocus="UsernameTextBox_LostFocus"/>

                <TextBlock Text="Пароль" FontWeight="SemiBold" Margin="0,15,0,5"
                          Foreground="{StaticResource TextDarkBrush}"/>
                <PasswordBox x:Name="PasswordBox" Height="40" Padding="10" 
                           BorderBrush="{StaticResource BeigeDarkBrush}"/>

                <!-- Кнопка входа -->
                <Button Content="🚀 Войти в систему" 
                       Height="45" 
                       Margin="0,30,0,0" 
                       Click="LoginButton_Click"
                       Background="{StaticResource BurgundyMainBrush}"
                       Foreground="White"
                       FontWeight="SemiBold"
                       FontSize="14"
                       BorderThickness="0"
                       Cursor="Hand"/>

                <!-- Подсказка -->
                <TextBlock Text="Логин: admin, Пароль: admin" 
                          Foreground="{StaticResource TextLightBrush}" 
                          FontSize="10" TextAlignment="Center" 
                          Margin="0,15,0,0"/>

                <!-- Сообщение об ошибке -->
                <TextBlock x:Name="ErrorText" Text="" Foreground="Red" FontSize="11" 
                          TextAlignment="Center" Margin="0,10,0,0" Visibility="Collapsed"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>