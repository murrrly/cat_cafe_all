<Window x:Class="RPM.CashierWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Касса" Height="700" Width="1100"
        WindowStartupLocation="CenterScreen">

	<Grid>
		<Grid.ColumnDefinitions>
			<ColumnDefinition Width="220"/>
			<ColumnDefinition Width="*"/>
		</Grid.ColumnDefinitions>

		<!-- ЛЕВАЯ ПАНЕЛЬ -->
		<Border Background="#3A3A3D">
			<StackPanel Margin="10">

				<TextBlock Text="КАССА"
                           Foreground="White"
                           FontSize="20"
                           Margin="0,10,0,30"
                           HorizontalAlignment="Center"/>

				<Button Content="Новый заказ" Height="50" Margin="0,5"
                        Click="NewOrder_Click"/>

				<Button Content="Список заказов" Height="50" Margin="0,5"
                        Click="OrdersList_Click"/>

				<Button Content="Выход" Height="40" Margin="0,40,0,0"
                        Background="#AA3333" Foreground="White"
                        Click="Exit_Click"/>
			</StackPanel>
		</Border>

		<!-- ПРАВАЯ ОБЛАСТЬ -->
		<Border Grid.Column="1" Background="#F8F8F8">
			<ContentControl x:Name="MainContent"/>
		</Border>

	</Grid>
</Window>
