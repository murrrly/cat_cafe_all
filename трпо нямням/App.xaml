<Application x:Class="RPM.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Application.Resources>
        <!-- Цветовая палитра -->
        <Color x:Key="BeigeLight">#FFF8F5F0</Color>
        <Color x:Key="BeigeMedium">#FFEFE6D8</Color>
        <Color x:Key="BeigeDark">#FFE0D5C2</Color>
        <Color x:Key="BurgundyMain">#FF8B0000</Color>
        <Color x:Key="BurgundyDark">#FF5A0000</Color>
        <Color x:Key="BurgundyLight">#FFA52A2A</Color>
        <Color x:Key="TextDark">#FF5C4B37</Color>
        <Color x:Key="TextLight">#FF8C7C69</Color>

        <!-- Кисти -->
        <SolidColorBrush x:Key="BeigeLightBrush" Color="{StaticResource BeigeLight}"/>
        <SolidColorBrush x:Key="BeigeMediumBrush" Color="{StaticResource BeigeMedium}"/>
        <SolidColorBrush x:Key="BeigeDarkBrush" Color="{StaticResource BeigeDark}"/>
        <SolidColorBrush x:Key="BurgundyMainBrush" Color="{StaticResource BurgundyMain}"/>
        <SolidColorBrush x:Key="BurgundyDarkBrush" Color="{StaticResource BurgundyDark}"/>
        <SolidColorBrush x:Key="BurgundyLightBrush" Color="{StaticResource BurgundyLight}"/>
        <SolidColorBrush x:Key="TextDarkBrush" Color="{StaticResource TextDark}"/>
        <SolidColorBrush x:Key="TextLightBrush" Color="{StaticResource TextLight}"/>

        <!-- Стили кнопок -->
        <Style x:Key="BurgundyButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource BurgundyMainBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" 
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource BurgundyDarkBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource BurgundyLightBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="NavButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="15,10"/>
            <Setter Property="Margin" Value="5,2"/>
            <Setter Property="Foreground" Value="{StaticResource TextDarkBrush}"/>
            <Setter Property="FontSize" Value="13"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource BeigeDarkBrush}"/>
                    <Setter Property="Foreground" Value="{StaticResource BurgundyMainBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Стиль для карточек -->
     
        <!-- Стиль для DataGrid -->
        <Style x:Key="ModernDataGridStyle" TargetType="DataGrid">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource BeigeDarkBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="RowDetailsVisibilityMode" Value="VisibleWhenSelected"/>
            <Setter Property="ScrollViewer.CanContentScroll" Value="True"/>
            <Setter Property="ScrollViewer.PanningMode" Value="Both"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="CanUserDeleteRows" Value="False"/>
            <Setter Property="CanUserReorderColumns" Value="False"/>
            <Setter Property="CanUserResizeColumns" Value="True"/>
            <Setter Property="CanUserResizeRows" Value="False"/>
            <Setter Property="CanUserSortColumns" Value="True"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource BeigeMediumBrush}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{StaticResource TextDarkBrush}"/>
        </Style>

        <!-- Стиль для заголовков -->
        <Style x:Key="HeaderTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextDarkBrush}"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="18"/>
        </Style>

        <!-- Стиль для подзаголовков -->
        <Style x:Key="SubHeaderTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextLightBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>

        <!-- Стиль для статусов в DataGrid -->
		<Style x:Key="StatusTextStyle" TargetType="TextBlock">
			<Setter Property="HorizontalAlignment" Value="Center"/>
			<Setter Property="Padding" Value="5,2"/>
			<Setter Property="Background" Value="{StaticResource BeigeMediumBrush}"/>
			<Setter Property="Foreground" Value="{StaticResource BurgundyMainBrush}"/>
			<Setter Property="FontWeight" Value="SemiBold"/>
		</Style>

		<Style x:Key="CardStyle" TargetType="Border">
			<Setter Property="Background" Value="White"/>
			<Setter Property="CornerRadius" Value="10"/>
			<Setter Property="Padding" Value="15"/>
			<Setter Property="Margin" Value="10"/>
			<Setter Property="Effect">
				<Setter.Value>
					<DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.2"/>
				</Setter.Value>
			</Setter>
		</Style>

	</Application.Resources>
</Application>