<Page x:Class="RPM.Pages.DashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#FFF8F5F2">

	<Grid Margin="20">
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="150"/>
			<RowDefinition Height="*"/>
		</Grid.RowDefinitions>

		<!-- Заголовок -->
		<TextBlock Text="Дашборд Sushi Cats Cafe"
                   FontSize="26" FontWeight="Bold"
                   Foreground="#5C2E2E"/>

		<!-- Стат карточки -->
		<Grid Grid.Row="1" Margin="0,20,0,20">
			<Grid.ColumnDefinitions>
				<ColumnDefinition/>
				<ColumnDefinition/>
				<ColumnDefinition/>
				<ColumnDefinition/>
			</Grid.ColumnDefinitions>

			<Border Style="{StaticResource CardStyle}" Grid.Column="0">
				<StackPanel>
					<TextBlock Text="Сегодня заказов"/>
					<TextBlock x:Name="TodayOrdersText" FontSize="28" FontWeight="Bold"/>
				</StackPanel>
			</Border>

			<Border Style="{StaticResource CardStyle}" Grid.Column="1">
				<StackPanel>
					<TextBlock Text="Выручка сегодня"/>
					<TextBlock x:Name="TodayRevenueText" FontSize="28" FontWeight="Bold"/>
				</StackPanel>
			</Border>

			<Border Style="{StaticResource CardStyle}" Grid.Column="2">
				<StackPanel>
					<TextBlock Text="Активных акций"/>
					<TextBlock x:Name="ActivePromotionsText" FontSize="28" FontWeight="Bold"/>
				</StackPanel>
			</Border>

			<Border Style="{StaticResource CardStyle}" Grid.Column="3">
				<StackPanel>
					<TextBlock Text="Блюд в меню"/>
					<TextBlock x:Name="MenuItemsText" FontSize="28" FontWeight="Bold"/>
				</StackPanel>
			</Border>
		</Grid>

		<!-- Последние заказы -->
		<DataGrid x:Name="RecentOrdersGrid" Grid.Row="2" AutoGenerateColumns="False">
			<DataGrid.Columns>
				<DataGridTextColumn Header="№" Binding="{Binding OrderNumber}"/>
				<DataGridTextColumn Header="Дата" Binding="{Binding OrderDate}"/>
				<DataGridTextColumn Header="Сумма" Binding="{Binding TotalAmount}"/>
				<DataGridTextColumn Header="Тип оплаты" Binding="{Binding PaymentType}"/>
			</DataGrid.Columns>
		</DataGrid>
	</Grid>
</Page>
